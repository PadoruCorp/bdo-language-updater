<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BDOLanguageUpdater.WPF.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="520"
        x:Class="BDOLanguageUpdater.WPF.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="BDO Language Updater"
        Width="760"
        Height="520"
        MinWidth="700"
        MinHeight="480"
        Icon="/Assets/icon.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.72"/>
        </Style>
        <Style Selector="TextBlock.Value">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.Panel">
            <Setter Property="Background" Value="#181B18"/>
            <Setter Property="BorderBrush" Value="#2F3932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#2F7D54"/>
            <Setter Property="BorderBrush" Value="#46A46E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#378F61"/>
            <Setter Property="BorderBrush" Value="#52B77D"/>
        </Style>
        <Style Selector="Button.Primary:pressed">
            <Setter Property="Background" Value="#246A45"/>
            <Setter Property="BorderBrush" Value="#3B8F60"/>
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#1B1F1B"/>
            <Setter Property="BorderBrush" Value="#3B473F"/>
            <Setter Property="Foreground" Value="#E7ECE6"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="#232923"/>
            <Setter Property="BorderBrush" Value="#536158"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Background="#101210">
        <Border Grid.Row="0" Background="#161916" BorderBrush="#2F3932" BorderThickness="0,0,0,1" Padding="22,18">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                    <TextBlock Text="BDO Language Updater" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Replace one installed regional language file with the latest official English localization."
                               Opacity="0.78"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Target: English"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#96D2B0"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="General">
                <Grid DataContext="{Binding GeneralTabViewModel}"
                      RowDefinitions="*,Auto"
                      Margin="0,14,0,0">

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14" Margin="0,0,0,14">
                            <Border Classes="Panel">
                                <Grid RowDefinitions="Auto,Auto">
                                    <TextBlock Classes="Label" Text="Black Desert Online folder"/>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                                        <TextBox Text="{Binding BDOPath}" IsReadOnly="True" PlaceholderText="Select the Black Desert Online folder"/>
                                        <Button Grid.Column="1" Content="Browse" Click="Browse" Margin="8,0,0,0"/>
                                        <Button Grid.Column="2" Content="Scan" Click="ScanLanguages" Margin="8,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Classes="Panel">
                                <Grid ColumnDefinitions="*,Auto,*">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="Label" Text="Installed language to replace"/>
                                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                                  SelectedItem="{Binding SelectedLanguage}"
                                                  MinWidth="240"
                                                  HorizontalAlignment="Stretch"
                                                  PlaceholderText="No languages found"/>
                                        <TextBlock Text="{Binding SelectedLanguageDescription}" Opacity="0.72"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text=">"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="#96D2B0"
                                               Margin="18,0"/>

                                    <StackPanel Grid.Column="2" Spacing="8">
                                        <TextBlock Classes="Label" Text="Replacement language"/>
                                        <TextBlock Classes="Value" Text="{Binding TargetLanguageDescription}"/>
                                        <TextBlock Text="Latest official BDO English localization file." Opacity="0.72"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#101210" BorderBrush="#2F3932" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                        <Grid RowDefinitions="Auto,Auto,Auto" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Opacity="0.82"
                                       Margin="0,0,0,8"/>
                            <ProgressBar Grid.Row="1"
                                         IsIndeterminate="True"
                                         IsVisible="{Binding IsUpdating}"
                                         Height="4"
                                         VerticalAlignment="Center"
                                         Margin="0,0,0,12"/>
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="Update And Launch Steam"
                                        Click="UpdateAndLaunchSteam"
                                        IsEnabled="{Binding CanUpdate}"
                                        Classes="Secondary"
                                        Padding="18,9"/>
                                <Button Content="Update And Launch Launcher"
                                        Click="UpdateAndLaunchStandaloneLauncher"
                                        IsEnabled="{Binding CanUpdate}"
                                        Classes="Secondary"
                                        Padding="18,9"/>
                                <Button Content="Update Language"
                                        Click="UpdateLanguage"
                                        IsEnabled="{Binding CanUpdate}"
                                        Classes="Primary"
                                        Padding="18,9"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Advanced">
                <StackPanel DataContext="{Binding AdvancedTabViewModel}" Spacing="12" Margin="0,14,0,0">
                    <Border Classes="Panel">
                        <StackPanel Spacing="10">
                            <ToggleSwitch Content="Hide to tray on close" IsChecked="{Binding HideToTrayOnClose}"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="Panel">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,220">
                            <ToggleSwitch Content="Auto update after game updates"
                                          IsChecked="{Binding AutoRepairEnabled}"
                                          IsEnabled="{Binding IsAutoRepairSupported}"/>

                            <TextBlock Grid.Row="1"
                                       Classes="Label"
                                       Text="Maintenance day"
                                       VerticalAlignment="Center"
                                       Margin="0,14,12,0"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding MaintenanceDays}"
                                      SelectedItem="{Binding SelectedMaintenanceDay}"
                                      IsEnabled="{Binding CanEditAutoRepairSchedule}"
                                      Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding AutoRepairStatus}"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Opacity="0.76"
                                       Margin="0,12,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
